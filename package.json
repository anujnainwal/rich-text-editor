{
  "name": "@meenainwal/rich-text-editor",
  "version": "1.0.2",
  "description": "A premium, lightweight, and framework-agnostic rich text editor with a sophisticated Slate & Indigo design.",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/test-editor.cjs",
  "module": "./dist/test-editor.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/test-editor.mjs",
      "require": "./dist/test-editor.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@vitest/browser": "^4.0.18",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "rich-text-editor",
    "wysiwyg",
    "editor",
    "vanilla-js",
    "typescript",
    "premium-ui",
    "contenteditable"
  ],
  "author": "Anuj Nainwal",
  "license": "MIT",
  "homepage": "https://github.com/meenainwal/rich-text-editor#readme"
}
